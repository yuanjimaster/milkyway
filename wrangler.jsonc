{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "v131-s01-lab",
  "compatibility_date": "2026-06-16",
  "main": "src/worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "none"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
